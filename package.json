{
  "name": "kanji-heatmap",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": "22"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --port 5174",
    "dev:cf": "vite --port 5173",
    "build": "eslint . && node scripts/generate-speed-katakana.mjs && tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b && tsc -p e2e/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "peek": "prettier --write . && eslint . && tsc -b && vite build && vite preview --host",
    "format": "prettier --write .",
    "generate-more-info": "node scripts/generate-more-info.mjs",
    "generate-speed-katakana": "node scripts/generate-speed-katakana.mjs",
    "deps:graph": "node scripts/generate-deps-graphs.mjs",
    "deps:madge": "mkdir -p dependency-graphs && madge --ts-config tsconfig.app.json --extensions ts,tsx --exclude \"(^|/)(test/|.*\\\\.(test|spec)\\\\.(ts|tsx)$)\" --image dependency-graphs/madge.svg src",
    "deps:madge:circular": "madge --ts-config tsconfig.app.json --extensions ts,tsx --circular src",
    "deps:cruise": "depcruise src --include-only \"^src\" --exclude \"\\\\.(test|spec)\\\\.(ts|tsx)$\"",
    "deps:cruise:svg": "mkdir -p dependency-graphs && depcruise src --include-only \"^src\" --exclude \"\\\\.(test|spec)\\\\.(ts|tsx)$\" -T dot --collapse 3 | dot -T svg > dependency-graphs/cruise.svg",
    "deps:cruise:folders": "mkdir -p dependency-graphs && depcruise src --include-only \"^src\" --exclude \"\\\\.(test|spec)\\\\.(ts|tsx)$\" -T ddot | dot -T svg > dependency-graphs/folders.svg",
    "deps:cruise:archi": "mkdir -p dependency-graphs && depcruise src --include-only \"^src\" --exclude \"\\\\.(test|spec)\\\\.(ts|tsx)$\" -T archi | dot -T svg > dependency-graphs/archi.svg",
    "deps:skott": "skott --tsconfig tsconfig.app.json --displayMode=webapp --ignorePattern=\".*\\\\.(test|spec)\\\\.(ts|tsx)$\" --ignorePattern=\"src/test/.*\" src/main.tsx"
  },
  "dependencies": {
    "@fontsource/dotgothic16": "^5.2.5",
    "@fontsource/hachi-maru-pop": "^5.2.8",
    "@fontsource/kiwi-maru": "^5.2.5",
    "@fontsource/klee-one": "^5.2.5",
    "@fontsource/noto-sans-jp": "^5.2.5",
    "@fontsource/noto-serif-jp": "^5.2.5",
    "@fontsource/nunito": "^5.2.5",
    "@fontsource/potta-one": "^5.2.8",
    "@fontsource/reggae-one": "^5.2.5",
    "@fontsource/stick": "^5.2.8",
    "@fontsource/yuji-boku": "^5.2.8",
    "@fontsource/yuji-mai": "^5.2.5",
    "@fontsource/yusei-magic": "^5.2.8",
    "@fontsource/zen-kurenaido": "^5.2.8",
    "@fontsource/zen-old-mincho": "^5.2.8",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "chart.js": "^4.4.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.0",
    "dmak": "^0.3.1",
    "fuzzysearch": "^1.0.3",
    "kanjicanvas": "github:asdfjkl/kanjicanvas",
    "lucide-react": "^0.474.0",
    "onnxruntime-web": "^1.27.0",
    "perfect-freehand": "^1.2.3",
    "raphael": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "virtua": "^0.40.3",
    "vite-plugin-pwa": "^0.21.1",
    "wanakana": "^5.3.1",
    "wouter": "^3.6.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.41.0",
    "@eslint/js": "^9.21.0",
    "@playwright/test": "~1.56.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/fuzzysearch": "^1.0.2",
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "autoprefixer": "^10.4.20",
    "dependency-cruiser": "^18.1.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "madge": "^8.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.2",
    "rollup-plugin-visualizer": "^5.14.0",
    "skott": "^0.35.11",
    "tailwindcss": "3.4.0",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.2.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.101.0"
  }
}
